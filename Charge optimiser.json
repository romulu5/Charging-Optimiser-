        "z": "tab-charge-opt",\
        "name": "Analyse prices",\
        "func": "const rows = msg.payload && msg.payload.data && msg.payload.data.ee;\\nif (!Array.isArray(rows)) \{\\n    node.error('Unexpected Elering payload', msg);\\n    node.status(\{ fill: 'red', shape: 'ring', text: 'parse error' \});\\n    return null;\\n\}\\nconst prices = rows.map(r => (\{\\n    ts: r.timestamp,\\n    hour_iso: new Date(r.timestamp * 1000).toISOString(),\\n    eur_mwh: r.price,\\n    c_kwh: r.price / 10\\n\}));\\nflow.set('prices', prices);\\nmsg.payload = prices;\\nconst stamp = new Date().toLocaleTimeString('et-EE');\\nnode.status(\{ fill: 'green', shape: 'dot', text: `$\{prices.length\} hours @ $\{stamp\}` \});\\nreturn msg;",\
