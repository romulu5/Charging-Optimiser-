        "z": "tab-charge-opt",\
        "name": "Build Elering URL",\
        "func": "const now = new Date();\\nnow.setMinutes(0, 0, 0);\\nconst end = new Date(now.getTime() + 24 * 60 * 60 * 1000);\\nconst fmt = d => d.toISOString().replace(/\\\\.\\\\d\{3\}/, '.000');\\nmsg.url = `https://dashboard.elering.ee/api/nps/price?start=$\{fmt(now)\}&end=$\{fmt(end)\}`;\\nmsg.method = 'GET';\\nreturn msg;",\
