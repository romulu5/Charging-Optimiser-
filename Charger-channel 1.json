        "name": "Seed defaults",\
        "func": "// Fires once shortly after flow start (and on manual redeploy).\\n// Pushes sane defaults to each dashboard widget AND primes flow.ch1_params.\\nconst defaults = \{\\n    cap: 500, init: 20, target: 90, power: 250,\\n    dur: 12, strategy: 'gentle_80', fit: true\\n\};\\nflow.set('ch1_params', defaults);\\n// Return parallel msgs \'97 one output per widget (see node config wires).\\nreturn [\\n    \{ payload: defaults.cap,      topic: 'cap'      \},\\n    \{ payload: defaults.init,     topic: 'init'     \},\\n    \{ payload: defaults.target,   topic: 'target'   \},\\n    \{ payload: defaults.power,    topic: 'power'    \},\\n    \{ payload: defaults.dur,      topic: 'dur'      \},\\n    \{ payload: defaults.strategy, topic: 'strategy' \},\\n    \{ payload: defaults.fit,      topic: 'fit'      \},\\n    \{ payload: \{ source: 'seed', text: 'Loaded defaults' \}, topic: 'log' \}\\n];\\n",\
