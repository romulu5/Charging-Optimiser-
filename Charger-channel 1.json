    \{\
        "id": "0bd63818a80a566d",\
        "type": "function",\
        "z": "16bb12a106bd8c3c",\
        "name": "Optimiser",\
        "func": "// ============================================================\\n// JS port of price-service/optimiser.py \'97 three modes.\\n// Triggered by Start or Reset button on the dashboard.\\n// Outputs: [state, soc, schedule_text, cost, saving, mqtt]\\n// ============================================================\\n\\nconst GENTLE_CAP = 80.0;\\nconst BIAS_DEFAULT = 0.30;\\n\\nif (msg.payload === 'reset') \{\\n    node.status(\{ fill: 'grey', shape: 'ring', text: 'reset' \});\\n    return [\\n        \{ payload: 'IDLE', topic: 'state' \},\\n        \{ payload: 0,      topic: 'soc' \},\\n        \{ payload: '-',    topic: 'schedule_text' \},\\n        \{ payload: 0,      topic: 'cost' \},\\n        \{ payload: 0,      topic: 'saving' \},\\n        \{ payload: \{ action: 'reset' \}, topic: 'charger/1/command' \}\\n    ];\\n\}\\nif (msg.payload !== 'start') \{ return null; \}\\n\\nconst p = flow.get('ch1_params') || \{\\n    cap: 500, init: 20, target: 90, power: 250,\\n    dur: 12, strategy: 'cheapest', fit: true\\n\};\\nconst prices = flow.get('prices');\\nif (!prices || prices.length === 0) \{\\n    node.status(\{ fill: 'red', shape: 'ring', text: 'no prices yet' \});\\n    return [\{ payload: 'ERROR: no price data', topic: 'state' \}];\\n\}\\n\\n// --- auto-detect slot length from consecutive timestamps ---\\nconst slotMinutes = prices.length > 1\\n    ? Math.max(1, Math.round((prices[1].ts - prices[0].ts) / 60))\\n    : 60;\\nconst slotHours = slotMinutes / 60;\\nconst windowSlots = Math.floor(p.dur / slotHours);\\nconst win = prices.slice(0, windowSlots);\\n\\nif (win.length === 0) \{\\n    return [\{ payload: 'ERROR: empty window', topic: 'state' \}];\\n\}\\n\\n// --- helpers ---\\nconst requiredSlotsFor = (wh) => Math.ceil(wh / (p.power * slotHours));\\nconst energyFor = (deltaPct) => p.cap * Math.max(0, deltaPct) / 100;\\n\\nlet chosen = [];\\nlet powerW = p.power;\\nlet requiredWh = 0;\\nlet effectiveTarget = p.target;\\nlet feasible = true;\\nlet reason = '';\\n\\nif (p.strategy === 'cheapest') \{\\n    effectiveTarget = p.target;\\n    requiredWh = energyFor(p.target - p.init);\\n    if (requiredWh > 0) \{\\n        const req = requiredSlotsFor(requiredWh);\\n        const n = Math.min(win.length, req);\\n        chosen = [...win].sort((a, b) => a.eur_mwh - b.eur_mwh).slice(0, n);\\n        powerW = Math.min(p.power, (requiredWh / n) / slotHours);\\n        feasible = req <= win.length;\\n        if (!feasible) reason = `Window too short: need $\{req\}, have $\{win.length\}.`;\\n    \} else \{\\n        reason = 'Target already reached.';\\n    \}\\n\\n\} else if (p.strategy === 'gentle_80') \{\\n    effectiveTarget = GENTLE_CAP;\\n    requiredWh = energyFor(GENTLE_CAP - p.init);\\n    if (requiredWh > 0) \{\\n        const req = requiredSlotsFor(requiredWh);\\n        const n = Math.min(win.length, req);\\n        // Score each slot: price_norm - bias * lateness_norm (lower wins)\\n        const prs = win.map(x => x.eur_mwh);\\n        const pmin = Math.min(...prs);\\n        const pmax = Math.max(...prs);\\n        const pspan = (pmax - pmin) || 1;\\n        const wlen = (win.length - 1) || 1;\\n        const ranked = win.map((h, idx) => (\{\\n            h, score: (h.eur_mwh - pmin) / pspan - BIAS_DEFAULT * (idx / wlen)\\n        \})).sort((a, b) => a.score - b.score);\\n        chosen = ranked.slice(0, n).map(r => r.h);\\n        powerW = Math.min(p.power, (requiredWh / n) / slotHours);\\n        feasible = req <= win.length;\\n        reason = feasible\\n            ? `Gentle: capped at $\{GENTLE_CAP\}%, deadline bias $\{BIAS_DEFAULT\}.`\\n            : `Window too short for gentle mode: need $\{req\}, have $\{win.length\}.`;\\n    \} else \{\\n        reason = `Already >= $\{GENTLE_CAP\}% cap.`;\\n    \}\\n\\n\} else if (p.strategy === 'max_in_window') \{\\n    // Take every slot below window median, stop before exceeding 100%.\\n    const sortedPrs = [...win].map(x => x.eur_mwh).sort((a, b) => a - b);\\n    const mid = sortedPrs.length % 2\\n        ? sortedPrs[(sortedPrs.length - 1) / 2]\\n        : (sortedPrs[sortedPrs.length / 2 - 1] + sortedPrs[sortedPrs.length / 2]) / 2;\\n    const headroomWh = p.cap * Math.max(0, 100 - p.init) / 100;\\n    const perSlotWh = p.power * slotHours;\\n    const cheap = win.filter(x => x.eur_mwh <= mid)\\n                     .sort((a, b) => a.eur_mwh - b.eur_mwh);\\n    let acc = 0;\\n    for (const h of cheap) \{\\n        if (acc + perSlotWh > headroomWh) break;\\n        chosen.push(h);\\n        acc += perSlotWh;\\n    \}\\n    powerW = p.power;\\n    requiredWh = acc;\\n    effectiveTarget = Math.min(100, p.init + (acc / p.cap) * 100);\\n    reason = `Max: $\{chosen.length\} slots below median $\{(mid / 10).toFixed(3)\} c/kWh.`;\\n\\n\} else \{\\n    return [\{ payload: `ERROR: unknown strategy $\{p.strategy\}`, topic: 'state' \}];\\n\}\\n\\nif (!feasible && !p.fit) \{\\n    return [\{ payload: `ERROR: $\{reason\}`, topic: 'state' \}];\\n\}\\n\\nchosen.sort((a, b) => a.ts - b.ts);\\nconst scheduledSlots = chosen.map(s => (\{\\n    ts: s.ts,\\n    slot_iso: s.hour_iso,\\n    eur_mwh: s.eur_mwh,\\n    c_kwh: s.c_kwh,\\n    power_w: powerW,\\n    energy_wh: powerW * slotHours,\\n    cost_eur: (powerW * slotHours / 1000) * (s.eur_mwh / 1000)\\n\}));\\n\\nconst totalEnergyWh = scheduledSlots.reduce((a, s) => a + s.energy_wh, 0);\\nconst totalCost = scheduledSlots.reduce((a, s) => a + s.cost_eur, 0);\\nconst finalSoc = Math.min(100, p.init + (totalEnergyWh / p.cap) * 100);\\n\\n// Naive reference: first N slots of window, same energy\\nconst naiveN = Math.max(1, scheduledSlots.length || requiredSlotsFor(requiredWh));\\nconst naivePerSlot = (requiredWh || totalEnergyWh) / naiveN;\\nconst naiveCost = win.slice(0, naiveN).reduce(\\n    (a, x) => a + (naivePerSlot / 1000) * (x.eur_mwh / 1000), 0);\\nconst saving = naiveCost - totalCost;  // can be negative if optimised is worse (should not happen)\\n\\nconst fmt = iso => new Date(iso).toLocaleTimeString('et-EE',\\n    \{ hour: '2-digit', minute: '2-digit', timeZone: 'Europe/Tallinn' \});\\nconst scheduleText = scheduledSlots.length\\n    ? scheduledSlots.map(s =>\\n        `$\{fmt(s.slot_iso)\}  $\{s.c_kwh.toFixed(3)\} c/kWh  $\{s.power_w.toFixed(0)\} W`\\n      ).join('\\\\n')\\n    : '(no slots \'97 target already met or window empty)';\\n\\nnode.status(\{ fill: feasible ? 'green' : 'yellow', shape: 'dot',\\n    text: `$\{p.strategy\} \'b7 $\{scheduledSlots.length\} slots \'b7 EUR $\{totalCost.toFixed(4)\}` \});\\n\\nreturn [\\n    \{ payload: feasible ? 'WAITING' : 'PARTIAL', topic: 'state' \},\\n    \{ payload: p.init, topic: 'soc' \},\\n    \{ payload: scheduleText, topic: 'schedule_text' \},\\n    \{ payload: totalCost, topic: 'cost' \},\\n    \{ payload: saving, topic: 'saving' \},\\n    \{ payload: \{\\n        action: 'schedule',\\n        strategy: p.strategy,\\n        params: p,\\n        effective_target_pct: effectiveTarget,\\n        slot_minutes: slotMinutes,\\n        required_energy_wh: requiredWh,\\n        total_cost_eur: totalCost,\\n        saving_eur: saving,\\n        naive_cost_eur: naiveCost,\\n        final_soc_pct: finalSoc,\\n        feasible: feasible,\\n        reason: reason,\\n        slots: scheduledSlots\\n      \}, topic: 'charger/1/command' \}\\n];\\n",\
        "outputs": 6,\
        "noerr": 0,\
