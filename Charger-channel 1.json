        "id": "b34f6930a6bb1221",\
        "type": "function",\
        "z": "16bb12a106bd8c3c",\
        "name": "Event log",\
        "func": "// Append a new event, write the whole rolling list to disk in a clean tabular layout.\\nconst MAX = 80;\\nlet events = flow.get('events') || [];\\nconst p = msg.payload || \{\};\\nconst text   = p.text || (typeof p === 'string' ? p : JSON.stringify(p));\\nconst source = (p.source || msg.topic || 'event').toString();\\n\\nconst now = new Date();\\nconst ts  = now.toLocaleTimeString('et-EE',\\n    \{ hour: '2-digit', minute: '2-digit', second: '2-digit',\\n      hour12: false, timeZone: 'Europe/Tallinn' \});\\n\\nevents.unshift(\{ t: ts, src: source.slice(0, 8), msg: text \});\\nif (events.length > MAX) events = events.slice(0, MAX);\\nflow.set('events', events);\\n\\n// Build a clean, fixed-width table. Newest first.\\nconst SRC_W = 10;\\nconst header =\\n    '+----------+------------+------------------------------------------------+\\\\n' +\\n    '|   time   |   source   | message                                        |\\\\n' +\\n    '+----------+------------+------------------------------------------------+';\\nconst rows = events.map(e => \{\\n    const src = `[$\{e.src\}]`.padEnd(SRC_W);\\n    return `| $\{e.t\} | $\{src\} | $\{(e.msg || '').slice(0, 46).padEnd(46)\} |`;\\n\});\\nconst footer =\\n    '+----------+------------+------------------------------------------------+\\\\n' +\\n    '# tail this file with:  tail -f event_log.txt\\\\n' +\\n    '# newest events shown at the top, max ' + MAX + ' kept.\\\\n';\\n\\nreturn \{ payload: header + '\\\\n' + rows.join('\\\\n') + '\\\\n' + footer \};\\n",\
