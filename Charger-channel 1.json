        "id": "dcfd512c79b0d10e",\
        "type": "function",\
        "z": "16bb12a106bd8c3c",\
        "name": "Remember params",\
        "func": "// Each UI widget sends a message tagged by msg.topic.\\n// We stash the latest value for each topic in flow context.\\nconst params = flow.get('ch1_params') || \{\\n    cap: 500, init: 20, target: 90, power: 250,\\n    dur: 12, strategy: 'cheapest', fit: true\\n\};\\nparams[msg.topic] = msg.payload;\\nflow.set('ch1_params', params);\\nnode.status(\{ fill: 'blue', shape: 'dot', text: JSON.stringify(params).slice(0, 60) \});\\nreturn null; // no downstream output \'97 we wait for Start click\\n",\
