        "id": "c5ba7592a9297ecf",\
        "type": "function",\
        "z": "16bb12a106bd8c3c",\
        "name": "Post-optimise fanout",\
        "func": "// Reads the MQTT-ready payload from fn-optimise (via the 6th output wire\\n// tapped into this node) and fans it out into four dashboard signals.\\nconst p = msg.payload;\\nif (!p || p.action !== 'schedule') \{ return null; \}\\n\\n// --- 1. Log entry ---\\nconst logEntry = \{\\n    source: 'optimise',\\n    text: `$\{p.strategy\} \'b7 $\{p.slots.length\} slots \'b7 ` +\\n          `target $\{p.effective_target_pct.toFixed(0)\}% \'b7 ` +\\n          `cost EUR $\{p.total_cost_eur.toFixed(4)\}` +\\n          (p.feasible ? '' : ' \'b7 PARTIAL')\\n\};\\n\\n// --- 2. Cost-comparison bar chart ---\\n// ui_chart bar format: one payload object, series across two bars.\\nconst naive = (typeof p.naive_cost_eur === \\"number\\") ? p.naive_cost_eur : (p.total_cost_eur + p.saving_eur);\\nconst chartMsg = \{\\n    payload: [\{\\n        series: ['Optimised', 'Charge now (naive)'],\\n        data: [[p.total_cost_eur], [naive]],\\n        labels: ['cost (EUR)']\\n    \}]\\n\};\\n\\n// --- 3. Effective-target text ---\\nconst effText = (Math.abs(p.effective_target_pct - p.params.target) < 0.1)\\n    ? `$\{p.effective_target_pct.toFixed(0)\} %`\\n    : `$\{p.effective_target_pct.toFixed(0)\} %  (user asked $\{p.params.target.toFixed(0)\} %)`;\\n\\n// --- 4. Feasibility badge ---\\nconst feasMsg = \{\\n    payload: p.feasible ? 'OK' : `\uc0\u9888  $\{p.reason || 'partial'\}`,\\n    // Colour via ui_text 'format' requires template; we send plain text.\\n\};\\n\\nconst naiveText = `$\{naive.toFixed(4)\}`;\\n\\nreturn [\\n    \{ payload: logEntry, topic: 'log' \},\\n    chartMsg,\\n    \{ payload: effText \},\\n    feasMsg,\\n    \{ payload: naiveText \}\\n];\\n",\
