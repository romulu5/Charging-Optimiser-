    \{\
        "id": "ba2ab5cb10d6449c",\
        "type": "function",\
        "z": "16bb12a106bd8c3c",\
        "name": "State machine",\
        "func": "// ============================================================\\n// Simulated charging state machine (clean version).\\n// Inputs (msg.topic):\\n//   engage  - msg.payload = full schedule from fn-optimise\\n//   tick    - external 1 Hz inject (3b-inject-tick)\\n//   cancel  - reset to IDLE\\n//   speed   - msg.payload = number (1, 60, 3600)\\n// Outputs: [state, soc, current_slot_text, log]\\n// ============================================================\\n\\nlet st = context.get('sm') || \{\\n    engaged: false, schedule: null,\\n    sim_ms: 0, soc: 0, status: 'IDLE', speed: 3600\\n\};\\n\\nfunction slotMs(sch) \{ return (sch.slot_minutes || 15) * 60 * 1000; \}\\nfunction fmtClock(ms) \{\\n    return new Date(ms).toLocaleTimeString('et-EE',\\n        \{ hour: '2-digit', minute: '2-digit', timeZone: 'Europe/Tallinn' \});\\n\}\\nfunction showStatus() \{\\n    const colour = st.status === 'CHARGING' ? 'green' :\\n                   st.status === 'DONE'     ? 'blue'  :\\n                   st.status === 'WAITING'  ? 'yellow':\\n                   st.status === 'IDLE'     ? 'grey'  : 'red';\\n    node.status(\{ fill: colour, shape: 'dot',\\n        text: `$\{st.status\} | x$\{st.speed\} | SoC $\{st.soc.toFixed(1)\}%` \});\\n\}\\n\\nconst oState = s => (\{ payload: s, topic: 'state' \});\\nconst oSoC   = s => (\{ payload: s, topic: 'soc' \});\\nconst oSlot  = s => (\{ payload: s, topic: 'current_slot' \});\\nconst oLog   = (src, text) => (\{ payload: \{ source: src, text \}, topic: 'log' \});\\n\\n// ---------- speed change ----------\\nif (msg.topic === 'speed') \{\\n    st.speed = Number(msg.payload) || 1;\\n    context.set('sm', st); showStatus();\\n    return [null, null, null, oLog('sm-spd', `speed -> x$\{st.speed\}`)];\\n\}\\n\\n// ---------- cancel / reset ----------\\nif (msg.topic === 'cancel' ||\\n   (msg.topic === 'engage' && msg.payload && msg.payload.action === 'reset')) \{\\n    st = \{ engaged: false, schedule: null,\\n           sim_ms: 0, soc: 0, status: 'IDLE', speed: st.speed \};\\n    context.set('sm', st); showStatus();\\n    return [oState('IDLE'), oSoC(0), oSlot('-'), oLog('sm-rst', 'reset')];\\n\}\\n\\n// ---------- engage ----------\\nif (msg.topic === 'engage' && msg.payload && msg.payload.action === 'schedule') \{\\n    const sch = msg.payload;\\n    if (!sch.slots || sch.slots.length === 0) \{\\n        return [oState('NO SLOTS'), null, oSlot('-'),\\n                oLog('sm-eng', 'engage with empty slots')];\\n    \}\\n    st.engaged  = true;\\n    st.schedule = sch;\\n    st.sim_ms   = sch.slots[0].ts * 1000;\\n    st.soc      = sch.params.init;\\n    st.status   = 'WAITING';\\n    context.set('sm', st); showStatus();\\n    return [\\n        oState('WAITING'),\\n        oSoC(+st.soc.toFixed(1)),\\n        oSlot(`engage @ $\{fmtClock(st.sim_ms)\}`),\\n        oLog('sm-eng', `engaged: $\{sch.slots.length\} slots, ` +\\n                       `target $\{sch.effective_target_pct.toFixed(0)\}%, x$\{st.speed\}`)\\n    ];\\n\}\\n\\n// ---------- tick ----------\\nif (msg.topic === 'tick') \{\\n    if (!st.engaged) \{ return null; \}\\n\\n    const sMs        = slotMs(st.schedule);\\n    const slotSec    = sMs / 1000;\\n    const advanceSec = st.speed;\\n\\n    const prevTs = st.sim_ms / 1000;\\n    const newTs  = prevTs + advanceSec;\\n\\n    // Sweep ALL slots that overlap [prevTs, newTs] so x3600 doesn't skip\\n    let chargedWh  = 0;\\n    let activeSlot = null;\\n    for (const s of st.schedule.slots) \{\\n        const overlapStart = Math.max(prevTs, s.ts);\\n        const overlapEnd   = Math.min(newTs, s.ts + slotSec);\\n        if (overlapEnd > overlapStart) \{\\n            chargedWh += s.power_w * ((overlapEnd - overlapStart) / 3600);\\n            activeSlot = s;\\n        \}\\n    \}\\n\\n    if (chargedWh > 0) \{\\n        const dPct = (chargedWh / st.schedule.params.cap) * 100;\\n        st.soc = Math.min(100, st.soc + dPct);\\n    \}\\n\\n    st.sim_ms += advanceSec * 1000;\\n\\n    const last        = st.schedule.slots[st.schedule.slots.length - 1];\\n    const scheduleEnd = last.ts + slotSec;\\n\\n    if (newTs >= scheduleEnd) \{\\n        st.status  = 'DONE';\\n        st.engaged = false;\\n        context.set('sm', st); showStatus();\\n        return [\\n            oState('DONE'),\\n            oSoC(+st.soc.toFixed(1)),\\n            oSlot(`done @ $\{fmtClock(st.sim_ms)\}`),\\n            oLog('sm-don', `complete: SoC $\{st.soc.toFixed(1)\}% ` +\\n                           `cost EUR $\{st.schedule.total_cost_eur.toFixed(4)\}`)\\n        ];\\n    \}\\n\\n    if (chargedWh > 0) \{\\n        st.status = 'CHARGING';\\n        context.set('sm', st); showStatus();\\n        return [\\n            oState('CHARGING'),\\n            oSoC(+st.soc.toFixed(1)),\\n            oSlot(`$\{fmtClock(st.sim_ms)\} | $\{activeSlot.c_kwh.toFixed(3)\} c/kWh | ` +\\n                  `$\{activeSlot.power_w.toFixed(0)\} W`),\\n            null\\n        ];\\n    \}\\n\\n    st.status = 'WAITING';\\n    context.set('sm', st); showStatus();\\n    return [\\n        oState('WAITING'),\\n        null,\\n        oSlot(`$\{fmtClock(st.sim_ms)\} | gap`),\\n        null\\n    ];\\n\}\\n\\nreturn null;\\n",\
