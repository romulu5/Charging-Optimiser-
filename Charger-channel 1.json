    \{\
        "id": "a910094a30778d38",\
        "type": "function",\
        "z": "16bb12a106bd8c3c",\
        "name": "Apply encoder params",\
        "func": "// Parse encoder params JSON from ESP and update both flow context AND\\n// the visible dashboard numeric widgets. The widget IDs in this flow are:\\n//   ui-cap, ui-init, ui-target, ui-power, ui-dur\\n// We emit one message per widget so the user actually sees the values change.\\n\\n// MQTT in node may auto-parse JSON to an object, or hand us a raw string,\\n// or even a Buffer. Handle all three.\\nlet p = msg.payload;\\nif (Buffer.isBuffer(p)) p = p.toString('utf8');\\nif (typeof p === 'string') \{\\n    try \{ p = JSON.parse(p); \}\\n    catch (e) \{\\n        return [null, null, null, null, null,\\n                \{ payload: \{ source: 'esp-enc', text: 'bad JSON: ' + p \}, topic: 'log' \}];\\n    \}\\n\}\\nif (typeof p !== 'object' || p === null) \{\\n    return [null, null, null, null, null,\\n            \{ payload: \{ source: 'esp-enc', text: 'unexpected payload type: ' + typeof p \}, topic: 'log' \}];\\n\}\\n\\nconst cur = flow.get('ch1_params') || \{\\n    cap: 500, init: 20, target: 90, power: 250,\\n    dur: 12, strategy: 'cheapest', fit: true\\n\};\\n\\ncur.cap    = Number(p.cap)    || cur.cap;\\ncur.init   = Number(p.init)   || cur.init;\\ncur.target = Number(p.target) || cur.target;\\ncur.power  = Number(p.power)  || cur.power;\\ncur.dur    = Number(p.dur)    || cur.dur;\\nflow.set('ch1_params', cur);\\n\\nconst summary = `cap=$\{cur.cap\}, init=$\{cur.init\}, target=$\{cur.target\}, power=$\{cur.power\}, dur=$\{cur.dur\}`;\\n\\n// Outputs (in order): cap, init, target, power, dur, log\\nreturn [\\n    \{ payload: cur.cap \},\\n    \{ payload: cur.init \},\\n    \{ payload: cur.target \},\\n    \{ payload: cur.power \},\\n    \{ payload: cur.dur \},\\n    \{ payload: \{ source: 'esp-enc', text: 'params from encoder: ' + summary \}, topic: 'log' \}\\n];\\n",\
        "outputs": 6,\
        "noerr": 0,\
